{
	"compilerOptions": {
		"target": "ES2021",
		"module": "commonjs",
		"baseUrl": "./",
		"paths": {
			"@/*": ["src/*"]
		},
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"noImplicitAny": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}
